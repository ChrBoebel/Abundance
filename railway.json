{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd nextjs_frontend && npm install && npm run build",
    "watchPatterns": [
      "nextjs_frontend/**",
      "src/**"
    ]
  },
  "deploy": {
    "startCommand": "cd nextjs_frontend && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
