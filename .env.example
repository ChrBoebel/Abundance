# ============================================
# Abundance - Environment Variables
# ============================================
# Kopiere diese Datei nach .env und setze deine Werte:
#   cp .env.example .env

# --- Authentifizierung (Required) ---
APP_PASSWORD=dein-passwort
SESSION_SECRET=mindestens-32-zeichen-langer-zufaelliger-string

# --- API Keys (Required) ---
GEMINI_API_KEY=dein-gemini-api-key
GOOGLE_API_KEY=dein-google-api-key
TAVILY_API_KEY=dein-tavily-api-key
OPENROUTER_API_KEY=dein-openrouter-api-key

# --- Optional API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LangSmith (Optional - Debugging/Tracing) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=false

# --- Port ---
PORT=4290
